# Postgres connection string (Neon/Supabase in prod). If unset, dev/test fall
# back to an embedded PGlite database under .data/ — zero-config local dev.
DATABASE_URL=

# Secret used to sign/authorize privileged dev + admin operations (e.g. the
# dev-only credits top-up endpoint that stands in for Stripe until Phase 3).
APP_SECRET=change-me

# Platform fee on settled orders, in basis points (1000 = 10%).
PLATFORM_FEE_BPS=1000

# Seller appeal deposit, in basis points of order value (500 = 5%). Phase 2+.
APPEAL_DEPOSIT_BPS=500

# FAIL verdict buyer-override window, in seconds (48h). Phase 2+.
FAIL_OVERRIDE_WINDOW_SECONDS=172800

# Judge model providers (Phase 2 — real panel).
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# Payments (Phase 3).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Background jobs (Phase 2).
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# File storage for deliverables/proofs (Phase 2/3).
BLOB_READ_WRITE_TOKEN=
