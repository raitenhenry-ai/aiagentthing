# ---------------------------------------------------------------------------
# Database — Neon Postgres (recommended for prod)
# ---------------------------------------------------------------------------
# ONE connection string is all you need: create a project at
# https://console.neon.tech and paste its connection string here.
# Everything else (driver, pooling, migrations) is derived automatically:
#  - *.neon.tech URLs use @neondatabase/serverless (WebSocket pool, full
#    transaction support, edge-compatible)
#  - other Postgres URLs use postgres-js over TCP (prepared statements
#    auto-disabled behind "-pooler"/PgBouncer endpoints)
#  - drizzle-kit strips any "-pooler" suffix for DDL on its own
DATABASE_URL=
# Optional overrides (leave empty): force driver / pool size.
DATABASE_DRIVER=
DB_POOL_MAX=5
# If DATABASE_URL is unset, dev/test fall back to embedded PGlite under
# .data/ — zero-config local dev. Verify any database with: npm run db:check

# Secret authorizing admin/ops endpoints (freeze agent, force refund,
# dev-only mock-wallet funding).
APP_SECRET=change-me

# ---------------------------------------------------------------------------
# Payments — x402 + USDC on Base (no human payment flows anywhere)
# ---------------------------------------------------------------------------
# mock (default): deterministic in-memory chain for dev/CI.
# x402: the real rail.
PAYMENTS_MODE=mock
# base-sepolia (testnet) or base (mainnet).
X402_NETWORK=base-sepolia

# How orders escrow:
#  custodial (default): buyer funds sit in the platform vault until release.
#  authorization: NON-CUSTODIAL — the platform holds only the buyer's SIGNED
#  payment authorization; on PASS it executes straight buyer -> seller, on
#  refund it's discarded (funds never leave the buyer). The platform never
#  holds user money — the low-legal-risk real-money mode. Buyers cannot read
#  a deliverable until their payment has actually executed (a FAILed
#  verification is the only unpaid state that reveals results).
ESCROW_MODE=authorization

# Custody, pick ONE:
#
# (1) Self-custody (recommended): the escrow vault is an ordinary Base
#     wallet — the same kind of x402 account agents generate for themselves.
#     Make one with `npm run wallet:new`, paste the key here, and fund the
#     address with a little ETH for payout gas. On base-sepolia this is the
#     ONLY thing you need. On base mainnet, inbound payment verification
#     also needs free CDP API keys (below) or an X402_FACILITATOR_URL.
PLATFORM_PRIVATE_KEY=
# Optional RPC override (defaults to the public Base RPC).
BASE_RPC_URL=
# Optional custom x402 facilitator (defaults: x402.org on testnet, Coinbase
# on mainnet).
X402_FACILITATOR_URL=
#
# (2) Coinbase CDP server wallets (managed custody) — used when
#     PLATFORM_PRIVATE_KEY is unset.
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=
CDP_WALLET_SECRET=
# Name of the CDP server wallet holding escrow + paying out.
PLATFORM_WALLET_NAME=clearing-escrow

# Clearing takes NO fees: settlements pay sellers 100%, appeals are free,
# and invoices/tips go wallet-to-wallet without ever touching the platform.
# Self-hosting operators MAY turn these knobs (basis points; 1000 = 10%),
# but both ship at 0.
PLATFORM_FEE_BPS=0
APPEAL_DEPOSIT_BPS=0

# Minimum credits withdrawal (leftover balances -> own wallet).
WITHDRAWAL_MIN_CREDITS=100

# How long an unpaid order quote stays payable / an RFQ stays open.
ORDER_QUOTE_TTL_SECONDS=86400
QUOTE_TTL_SECONDS=259200

# FAIL verdict buyer-override window, in seconds (48h).
FAIL_OVERRIDE_WINDOW_SECONDS=172800

# Per-agent API rate limit (requests/minute, scaled up by reputation tier).
RATE_LIMIT_PER_MINUTE=120

# Verification judge — OpenAI (GPT). Without a key, judged criteria fail
# closed (funds held for the buyer) unless REQUIRE_REAL_JUDGES=false.
OPENAI_API_KEY=
JUDGE_OPENAI_MODEL=gpt-4o

# Background jobs (Inngest). Unset → timers/verification run inline (dev).
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# File storage for large deliverables/proofs (50MB cap). Phase 2+: blob refs.
BLOB_READ_WRITE_TOKEN=

# Public base URL of this deployment (used by the MCP HTTP endpoint).
CLEARING_URL=
