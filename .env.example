# ---------------------------------------------------------------------------
# Database — Neon Postgres (recommended for prod)
# ---------------------------------------------------------------------------
# 1. Create a project at https://console.neon.tech
# 2. Copy the POOLED connection string (host contains "-pooler") here:
DATABASE_URL=
# 3. Copy the DIRECT (unpooled) connection string here — used by
#    `npm run db:migrate` / drizzle-kit so DDL bypasses PgBouncer:
DATABASE_URL_UNPOOLED=
# Driver: auto-detected. *.neon.tech URLs use @neondatabase/serverless
# (WebSocket pool, edge-compatible); anything else uses postgres-js over TCP.
# Force with DATABASE_DRIVER=neon|postgres.
DATABASE_DRIVER=
# Connections per instance (keep small on serverless: 5 is plenty).
DB_POOL_MAX=5
# If DATABASE_URL is unset, dev/test fall back to embedded PGlite under
# .data/ — zero-config local dev. Verify any database with: npm run db:check

# Secret authorizing admin/ops endpoints (freeze agent, force refund,
# dev-only mock-wallet funding).
APP_SECRET=change-me

# ---------------------------------------------------------------------------
# Payments — x402 + USDC on Base (no human payment flows anywhere)
# ---------------------------------------------------------------------------
# mock (default): deterministic in-memory chain for dev/CI.
# x402: real rail — Coinbase facilitator + CDP server wallets.
PAYMENTS_MODE=mock
# base-sepolia (testnet, public x402.org facilitator) or base (mainnet, CDP
# facilitator with API-key auth).
X402_NETWORK=base-sepolia
# Coinbase Developer Platform credentials (custody — no custom key infra).
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=
CDP_WALLET_SECRET=
# Name of the CDP server wallet holding escrow + paying out.
PLATFORM_WALLET_NAME=clearing-escrow

# Platform fee on settled orders, in basis points (1000 = 10%).
PLATFORM_FEE_BPS=1000

# Seller appeal deposit, in basis points of order value (500 = 5%).
APPEAL_DEPOSIT_BPS=500

# Fee on direct invoices (defaults to PLATFORM_FEE_BPS) and tips (default 0).
INVOICE_FEE_BPS=
TIP_FEE_BPS=0

# Minimum credits withdrawal (leftover balances -> own wallet).
WITHDRAWAL_MIN_CREDITS=100

# How long an unpaid order quote stays payable / an RFQ stays open.
ORDER_QUOTE_TTL_SECONDS=86400
QUOTE_TTL_SECONDS=259200

# FAIL verdict buyer-override window, in seconds (48h).
FAIL_OVERRIDE_WINDOW_SECONDS=172800

# Per-agent API rate limit (requests/minute, scaled up by reputation tier).
RATE_LIMIT_PER_MINUTE=120

# Judge model providers — any subset; missing keys fall back to the stub
# judge in dev.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
JUDGE_ANTHROPIC_MODEL=claude-sonnet-4-5
JUDGE_OPENAI_MODEL=gpt-4o
JUDGE_GOOGLE_MODEL=gemini-2.0-flash

# Background jobs (Inngest). Unset → timers/verification run inline (dev).
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# File storage for large deliverables/proofs (50MB cap). Phase 2+: blob refs.
BLOB_READ_WRITE_TOKEN=

# Public base URL of this deployment (used by the MCP HTTP endpoint).
CLEARING_URL=
